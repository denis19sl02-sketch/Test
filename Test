<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Denisx 19</title>

<style>
body{
    margin:0;
    overflow:hidden;
    background:black;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    font-family:Arial;
}

h1{
    color:#00bfff;
    font-size:100px;
    text-shadow:
    0 0 10px #00bfff,
    0 0 20px #00bfff,
    0 0 40px #00bfff,
    0 0 80px #00bfff;
    animation:pulse 2s infinite alternate;
}

.color{
    position:absolute;
    border-radius:50%;
    filter:blur(80px);
    animation:move 10s infinite alternate;
}

.c1{
    width:300px;
    height:300px;
    background:#00bfff;
    top:10%;
    left:10%;
}

.c2{
    width:250px;
    height:250px;
    background:#0044ff;
    bottom:10%;
    right:10%;
}

@keyframes pulse{
    from{transform:scale(1);}
    to{transform:scale(1.06);}
}

@keyframes move{
    from{
        transform:translate(0,0) scale(1);
    }    height:100%;
    border:none;
    z-index:1;
}

@keyframes pulse{
    from{transform:scale(1);}
    to{transform:scale(1.06);}
}
</style>
</head>

<body>

<h1>Denisx 19</h1>

<iframe src="colors.html"></iframe>

</body>
</html>
